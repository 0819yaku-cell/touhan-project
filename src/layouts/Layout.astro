---
import '../styles/global.css';
import Footer from '../components/Footer.astro';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "登録販売者のくすり教室",
	description = "登録販売者試験の対策ができるクイズサイトです。現役薬剤師が詳しく解説。合格を目指して頑張りましょう！"
} = Astro.props;
---
<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="google-site-verification" content="gyDsl6h4HoosI8JhjPegIC0tD6VGLVGgAWvigYaS2FA" />
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet">
	</head>
	<body class="min-h-screen flex flex-col">
		<slot />
		<Footer />
		<!-- MermaidJS for Flowcharts -->
		<script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
		<script>
		  function initMermaid() {
		    if ((window as any).mermaid) {
		      (window as any).mermaid.initialize({
		        startOnLoad: false,
		        theme: 'base',
		        flowchart: { useMaxWidth: true, htmlLabels: true }
		      });
		    }
		  }
		  document.addEventListener('DOMContentLoaded', initMermaid);
		  document.addEventListener('astro:page-load', initMermaid);
		</script>
	</body>
</html>

<style is:global>
  /* ================================================
   * CRITICAL MOBILE RESET — guaranteed in every build
   * ================================================ */

  /* 1. Prevent any element from ever exceeding viewport width */
  html {
    overflow-x: clip;
    max-width: 100vw;
  }

  body {
    overflow-x: clip;
    width: 100%;
    max-width: 100vw;
    position: relative;
  }

  /* 2. Universal box-sizing so padding doesn't add to width */
  *, *::before, *::after {
    box-sizing: border-box;
  }

  /* 3. All block/flex/grid elements are bounded by parent */
  div, section, main, aside, header, footer, article, nav {
    max-width: 100%;
    min-width: 0;
  }

  /* 4. Images never overflow */
  img, video, canvas, svg, iframe {
    max-width: 100%;
    height: auto;
    display: block;
  }

  /* 5. Main page container — single column, mobile-first */
  .page-wrapper {
    width: 100%;
    max-width: 480px;
    margin: 0 auto;
    padding: 0;
  }

  .container {
    width: 100%;
    max-width: 480px;
    margin: 0 auto;
    padding: 0 1rem;
    box-sizing: border-box;
  }

  /* 6. Content grid ALWAYS single column */
  .content-grid {
    display: block !important;
    width: 100%;
  }

  /* 7. Quiz cards never overflow */
  .quiz-container,
  .quiz-card,
  .quiz-list,
  .main-content,
  .sidebar {
    width: 100%;
    max-width: 100%;
    min-width: 0;
    box-sizing: border-box;
  }
</style>
