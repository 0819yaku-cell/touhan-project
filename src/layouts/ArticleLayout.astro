---
import Layout from './Layout.astro';
import AuthorBio from '../components/AuthorBio.astro';
import { getCollection } from 'astro:content';
import articlesJson from '../data/articles.json';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  category?: string;
  slug?: string;
}

const { title, description, noindex, category, slug } = Astro.props;

const normalizeEntries = (entries: any[], prefix: string) =>
  entries.map(entry => {
    const urlSlug = entry.data.slug ?? entry.id;
    return {
      href: `/articles/${prefix}/${urlSlug}`,
      slug: urlSlug,
      title: entry.data.title,
      description: entry.data.description ?? '',
      date: entry.data.pubDate ?? '',
      image: entry.data.image ?? `/記事画像/${urlSlug}.webp`,
      category: entry.data.category ?? '',
    };
  });

const [kampoEntries, otcEntries, studyEntries, careerEntries, examEntries] = await Promise.all([
  getCollection('kampo'),
  getCollection('otc'),
  getCollection('study'),
  getCollection('career'),
  getCollection('exam'),
]);

const jsonNormalized = (articlesJson as any[]).map(a => ({
  href: `/articles/${a.slug}`,
  slug: a.slug,
  title: a.title,
  description: a.description ?? '',
  date: a.date,
  image: a.image,
  category: a.category,
}));

const allArticles = [
  ...normalizeEntries(kampoEntries, 'kampo'),
  ...normalizeEntries(otcEntries, 'otc'),
  ...normalizeEntries(studyEntries, 'study'),
  ...normalizeEntries(careerEntries, 'career'),
  ...normalizeEntries(examEntries, 'exam'),
  ...jsonNormalized,
].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const relatedArticles = category
  ? allArticles.filter(a => a.category === category && a.slug !== slug).slice(0, 3)
  : [];
---

<Layout title={title} description={description} noindex={noindex}>
  <slot name="head" slot="head" />
  <slot />
  <AuthorBio />

  {relatedArticles.length > 0 && (
    <div id="auto-related" class="auto-related-wrap" style="display:none">
      <div class="auto-related-inner">
        <h2 class="auto-related-heading">関連記事</h2>
        <div class="auto-related-grid">
          {relatedArticles.map(article => (
            <a href={article.href} class="auto-related-card">
              <div class="auto-related-image">
                <img src={article.image} alt={article.title} loading="lazy" />
              </div>
              <div class="auto-related-body">
                <span class="auto-related-category">{article.category}</span>
                <h3 class="auto-related-title">{article.title}</h3>
                <p class="auto-related-desc">{article.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  )}
</Layout>

<script is:inline>
  // 訪問記録: URL末尾のslugをローカルストレージに保存
  try {
    const parts = window.location.pathname.split('/').filter(Boolean);
    const slug = parts[parts.length - 1];
    if (slug) {
      const visited = new Set(JSON.parse(localStorage.getItem('touhan_visited_articles') || '[]'));
      visited.add(slug);
      localStorage.setItem('touhan_visited_articles', JSON.stringify([...visited]));
    }
  } catch(e) {}
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const hasManual = document.querySelector('.related-links');
    const autoSection = document.getElementById('auto-related');
    if (!hasManual && autoSection) {
      autoSection.style.display = 'block';
    }
  });
</script>

<style is:global>
  .auto-related-wrap {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 1rem 3rem;
  }

  .auto-related-inner {
    border-top: 2px solid #f1f5f9;
    padding-top: 2rem;
  }

  .auto-related-heading {
    font-size: 1.1rem;
    font-weight: 900;
    color: #1e293b;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .auto-related-heading::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 1.2em;
    background: var(--color-primary, #0ea5e9);
    border-radius: 4px;
    flex-shrink: 0;
  }

  .auto-related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }

  .auto-related-card {
    display: flex;
    flex-direction: column;
    background: white;
    border-radius: 16px;
    text-decoration: none;
    border: 1px solid #f1f5f9;
    box-shadow: 0 2px 8px rgba(0,0,0,0.03);
    transition: all 0.3s ease;
    overflow: hidden;
  }

  .auto-related-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.06);
    border-color: #e2e8f0;
  }

  .auto-related-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    flex-shrink: 0;
  }

  .auto-related-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .auto-related-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    padding: 0.5rem;
  }

  .auto-related-category {
    font-size: 0.6rem;
    font-weight: 800;
    color: var(--color-primary-dark, #0284c7);
    background: #f0f9ff;
    padding: 2px 6px;
    border-radius: 9999px;
    display: inline-block;
    margin-bottom: 0.3rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  .auto-related-title {
    font-size: 0.75rem;
    font-weight: 900;
    color: #1e293b;
    line-height: 1.4;
    margin-bottom: 0.2rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .auto-related-desc {
    font-size: 0.65rem;
    color: #64748b;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }
</style>
