---
import Layout from '../layouts/Layout.astro';
import data from '../data/questions.json';
import articles from '../data/articles.json';

// --- 進捗表示用のデータ構造の生成 ---
const chapterTitles: Record<string, string> = {
  "第1章": "医薬品に共通する特性と基本的な知識",
  "第2章": "人体の働きと医薬品",
  "第3章": "主な医薬品とその作用",
  "第4章": "薬事関係法規・制度",
  "第5章": "医薬品の適正使用・安全対策"
};

const chaptersMap = new Map();

// --- テーマ名（単元）の「マイルド化」変換マッピング ---
const themeNameMap: Record<string, string> = {
  // 第1章・第2章
  "医薬品の本質": "お薬の役割",
  "医薬品の適正使用": "正しい使い方",
  "薬害の歴史": "薬害の教訓",
  "人体の構造と働き（内臓群）": "消化器や呼吸器など",
  "人体の構造と働き（感覚・神経・運動）": "目・耳・鼻・脳・骨など",
  "薬の働く仕組み（体内動態と剤形）": "薬が効く流れと形",
  "主な副作用": "注意したい副作用",

  // 第3章: 主な医薬品とその作用
  "精神神経系に作用する薬": "風邪や痛み・眠気の薬",
  "呼吸器官に作用するお薬（鎮咳去痰薬、口腔咽喉薬など）": "鎮咳去痰薬、口腔咽喉薬など",
  "胃腸に作用するお薬（胃腸薬、止瀉薬、瀉下薬など）": "胃腸薬、止瀉薬、瀉下薬など",
  "心臓などの器官や血液に作用するお薬（強心薬、高コレステロール改善薬、貧血用薬など）": "強心薬、高コレステロール改善薬など",
  "排泄に関わる部位に作用するお薬（痔の薬、尿路疾患用薬）、婦人薬": "痔・泌尿器・婦人薬",
  "婦人薬": "女性向けの薬",
  "アレルギー用薬": "アレルギーの薬",
  "鼻に用いる薬": "鼻炎の薬",
  "眼科用薬": "目薬",
  "皮膚に用いる薬": "皮膚の薬・塗り薬",
  "歯や口内に用いる薬": "歯と口の薬",
  "禁煙補助剤": "禁煙サポート薬",
  "滋養強壮保健薬": "栄養剤・ビタミン剤",
  "漢方処方製剤・生薬製剤": "漢方・生薬",
  "公衆衛生用薬": "消毒薬と殺虫剤",
  "一般用検査薬": "検査薬（妊娠・尿糖など）",
  "歯痛・歯槽膿漏薬、禁煙補助剤、滋養強壮保健薬、漢方処方製剤・生薬製剤など": "歯痛・滋養強壮・漢方など",
  "アレルギー用薬（鼻炎用内服薬など）、点眼薬、皮膚に用いるお薬": "アレルギー・点眼・皮膚薬など",

  // 第4章: 薬事関係法規・制度
  "薬事関係法規・制度": "お薬の法律とルール",
  "薬事関係法規・制度（医薬品医療機器等法の目的、医薬品の分類・取扱い等）": "法律の目的、分類など",
  "薬事関係法規・制度（店舗販売業・配置販売業などの許可、医薬品の販売・情報提供、適正な広告、行政の監督など）": "販売の許可、広告など",

  // 第5章: 医薬品の適正使用・安全対策
  "医薬品の適正使用・安全対策": "安全に使うための情報",
  "医薬品の適正使用・安全対策（添付文書の読み方、してはいけないこと、相談すること、保管・取扱い等）": "添付文書、保管、取扱いなど",
  "医薬品の適正使用・安全対策（副作用被害救済制度、副作用等の報告制度、PL法など）": "救済制度・報告・啓発・PL法など",
  "医薬品の適正使用・安全対策（副作用被害救済制度、副作用等の報告制度、医薬品の啓発活動など）": "救済制度・報告・啓発・PL法など"
};

// 先に第1章〜第5章までの枠を全て作成しておく
Object.keys(chapterTitles).forEach(cName => {
  chaptersMap.set(cName, {
    name: cName,
    title: chapterTitles[cName],
    total: 0,
    themesMap: new Map()
  });
});

data.forEach((q: any) => {
  const cName = typeof q.chapter === 'number' ? `第${q.chapter}章` : (q.chapter ?? "");
  if (chaptersMap.has(cName)) {
    const chapObj = chaptersMap.get(cName);
    chapObj.total++;

    const rawThemeName = q.theme || q.category || "その他";
    // マッピング辞書にあれば変換し、なければそのまま使う
    const tName = themeNameMap[rawThemeName] || rawThemeName;
    
    if (!chapObj.themesMap.has(tName)) {
      chapObj.themesMap.set(tName, {
        name: tName,
        questions: []
      });
    }
    chapObj.themesMap.get(tName).questions.push(q);
  }
});

// Mapから配列に変換
const chapters = Array.from(chaptersMap.values()).map(c => ({
  ...c,
  themes: Array.from(c.themesMap.values())
}));

// 章番号順に並び替え
chapters.sort((a, b) => {
  const numA = parseInt(a.name.replace(/\D/g, '')) || 0;
  const numB = parseInt(b.name.replace(/\D/g, '')) || 0;
  return numA - numB;
});

// 🌿 漢方セクション用の特定記事抽出（葛根湯と防風通聖散を先頭に固定）
const prioritySlugs = ['kakkonto', 'bofutsushosan'];
const priorityArticles = prioritySlugs.map(slug => articles.find(a => a.slug === slug)).filter(Boolean);
const herbArticles = [
  ...priorityArticles,
  ...articles.filter(a => a.category.includes('漢方') && !prioritySlugs.includes(a.slug))
];
const otherArticles = articles.filter(a => !a.category.includes('漢方'));

const categoryGroups: Record<string, typeof otherArticles> = {
  "試験情報": [],
  "勉強法": [],
  "OTC・薬の知識": [],
  "キャリア・資格": [],
};

otherArticles.forEach(a => {
  const cat = (a as any).category;
  if (cat.includes("試験") || cat.includes("スケジュール") || cat.includes("合格率")) {
    categoryGroups["試験情報"].push(a);
  } else if (cat.includes("勉強") || cat.includes("テキスト") || cat.includes("通信")) {
    categoryGroups["勉強法"].push(a);
  } else if (cat.includes("お薬") || cat.includes("OTC") || cat.includes("薬の知識")) {
    categoryGroups["OTC・薬の知識"].push(a);
  } else if (cat.includes("キャリア") || cat.includes("資格") || cat.includes("主婦") || cat.includes("給料")) {
    categoryGroups["キャリア・資格"].push(a);
  } else {
    categoryGroups["試験情報"].push(a);
  }
});
---

<Layout>
  <div class="container page-wrapper py-xl animate-fade-in">
    <div class="content-grid">
      <!-- Main Content -->
      <main class="main-content">
        <header class="hero-section mb-xl">
          <div class="hero-image-wrapper">
            <!-- SEO用: 見た目上は非表示にしつつクローラーには認識させる -->
            <h1 class="sr-only">登録販売者のくすり教室</h1>
            <p class="sr-only">全国共通範囲に対応（最新基準を完全網羅）現役薬剤師が本気で噛み砕いた、一番やさしい過去問解説</p>
            <img src="/top-hero-official.webp" alt="登録販売者のくすり教室 全国共通範囲に対応（最新基準を完全網羅） 現役薬剤師が本気で噛み砕いた、一番やさしい過去問解説" class="hero-img" loading="eager" fetchpriority="high" />
          </div>
          <div class="hero-catch-text px-4 pt-4 pb-2">
            <h1 class="text-lg font-black text-slate-800 leading-snug mb-2">
              登録販売者試験対策<br>
              <span class="text-primary">現役薬剤師が作った無料学習サイト</span>
            </h1>
            <p class="text-sm text-slate-500 font-bold leading-relaxed">
              18年の現場経験を持つ薬剤師が全国共通範囲を完全網羅。
              480問の練習問題とやさしい解説で、スキマ時間に合格力を身につけよう。
            </p>
          </div>
        </header>

        <!-- CTA Section -->
        <section class="cta-section text-center mb-xl">
          <div class="feature-badges flex justify-around mb-6 px-2">
            <div class="feature-badge text-center">
              <div class="text-2xl mb-1">🩺</div>
              <div class="text-xs font-black text-slate-600 leading-tight">現役薬剤師<br>18年監修</div>
            </div>
            <div class="feature-badge text-center">
              <div class="text-2xl mb-1">📝</div>
              <div class="text-xs font-black text-slate-600 leading-tight">480問＋<br>模擬テスト</div>
            </div>
            <div class="feature-badge text-center">
              <div class="text-2xl mb-1">⏱</div>
              <div class="text-xs font-black text-slate-600 leading-tight">1日10問で<br>コツコツ合格</div>
            </div>
          </div>
          <div class="stats-container mb-md">
            <p class="stats-text font-bold text-lg text-slate-600">
              現在のマスター数：<span id="global-mastered-count" class="text-primary-dark text-2xl mx-1">0</span> / {data.length}問
            </p>
          </div>
          
          <div class="cta-buttons flex flex-col items-center gap-4 w-full mx-auto px-4">
            <button id="btn-start-daily" class="btn-primary-lg w-full cursor-pointer border-0 !py-5 !text-[1.1rem] !rounded-2xl shadow-md">
              <span>今日の10問を始める</span>
            </button>
            <p class="text-[0.7rem] font-bold text-slate-400 mt-[-6px] opacity-80 italic">※マスターした問題は自動で除外されます</p>
            
            <div class="grid grid-cols-2 gap-4 w-full">
              <!-- 左: 模擬テスト120問 -->
              <a href="/mock-exam" id="btn-mock-exam" class="w-full py-6 px-2 bg-indigo-50 border-[3px] border-indigo-200 text-indigo-700 font-bold text-[0.95rem] leading-tight rounded-2xl shadow-sm hover:bg-indigo-100 active:scale-95 transition-all cursor-pointer flex flex-col items-center justify-center gap-3 h-full no-underline">
                <svg viewBox="0 0 24 24" width="32" height="32" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" class="opacity-90"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                <span>模擬テスト<br>120問</span>
              </a>
              
              <!-- 右: 好きな所から始める -->
              <button id="btn-scroll-modules" class="w-full py-6 px-2 bg-emerald-100 border-[3px] border-emerald-200 text-emerald-700 font-bold text-[0.95rem] leading-tight rounded-2xl shadow-sm hover:bg-emerald-100 active:scale-95 transition-all cursor-pointer flex flex-col items-center justify-center gap-3 h-full">
                <svg viewBox="0 0 24 24" width="32" height="32" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" class="opacity-90"><path d="M4 9h16"></path><path d="M4 15h16"></path><path d="M10 3L8 21"></path><path d="M16 3l-2 18"></path></svg>
                <span>好きな所から<br>始める</span>
              </button>
            </div>

            <!-- エンドレス3章：武者修行モード -->
            <a href="/endless-ch3" class="w-full mt-4 py-5 px-4 bg-orange-50/50 border-[3px] border-orange-100 text-orange-700/80 font-bold text-[0.95rem] leading-tight rounded-2xl shadow-sm hover:bg-orange-50 active:scale-95 transition-all cursor-pointer flex items-center justify-center gap-3 no-underline">
              <span>エンドレス3章：武者修行モード</span>
            </a>
          </div>
          
          <!-- scriptで使用するための見えないデータ要素 -->
          <div id="quiz-data-ids" data-ids={JSON.stringify(data.map((q: any) => q.id))} class="hidden"></div>
        </section>


        <!-- Herb Article Section -->
        <section class="herb-highlights-section px-4 mb-xl">
          <div class="flex items-center justify-between mb-4 mt-2">
            <h2 class="text-xl font-black text-slate-800 flex items-center gap-2">
              <span class="w-2 h-6 bg-primary rounded-full"></span>
              漢方を深く理解する
            </h2>
            <a href="/articles" class="btn-outline-sm no-underline">漢方記事一覧</a>
          </div>
          <p class="text-[0.75rem] font-bold text-slate-500 pl-4 mb-6">試験に出る漢方を薬剤師が徹底解説</p>
          
          <div class="herb-scroll-container hide-scrollbar">
            <div class="herb-flex-wrapper">
              {herbArticles.map((article) => (
                <a href={`/articles/${article.slug}`} class="herb-card snap-start">
                  <div class="herb-card-image">
                    <img src={article.image} alt={article.title} />
                  </div>
                  <div class="herb-card-content">
                    <span class="herb-category-badge">{article.category}</span>
                    <h3 class="herb-card-title">{article.title}</h3>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>


        <!-- Chapters Progress Section -->
        <section id="modules-section" class="modules-section mb-xl">
          <div class="px-4 mb-6">
            <h2 class="section-title text-xl font-black text-slate-800 flex items-center gap-2 mb-2">
              <span class="w-2 h-6 bg-primary rounded-full"></span>
              章ごとに学習する
            </h2>
            <p class="text-sm font-bold text-slate-500 pl-4">章をタップ → 単元を選んで学習できます</p>
          </div>
          <div class="modules-grid">
            {chapters.map((chap, i) => {
              const numMatch = chap.name.match(/\d/);
              const chapterNum = numMatch ? parseInt(numMatch[0] || "1", 10) : 1;
              const colorClasses = [
                "chap-color-1", // Pink
                "chap-color-2", // Blue
                "chap-color-3", // Green
                "chap-color-4", // Orange
                "chap-color-5"  // Purple
              ];
              const themeClass = colorClasses[(chapterNum - 1) % 5];
              return (
              <div class={`chap-tile-wrapper ${themeClass}`}>
                <button class="chap-tile text-left w-full cursor-pointer border-none bg-transparent p-0 m-0 relative">
                  <div class="chap-tile-header">
                    <span class="chap-badge">{chap.name}</span>
                    <span class="chap-progress-badge" id={`chap-progress-text-${i}`}>0%</span>
                  </div>
                  <h3 class="chap-tile-title pr-8">{chap.title}</h3>
                  <div class="chap-progress-bar-container">
                    <div class="chap-progress-bar" id={`chap-progress-bar-${i}`} style="width: 0%"></div>
                  </div>
                  <span class="accordion-icon">▼</span>
                </button>
                <div class="chap-themes" id={`chap-content-${i}`}>
                  {chap.themes.length > 0 ? (
                    <div class="flex flex-col gap-4 mt-1">
                      <div class="theme-pills flex flex-wrap gap-2">
                        {chap.themes.map((theme: any, j: number) => {
                          const qIds = theme.questions.map((q: any) => q.id).join(',');
                          const rawThemeName = theme.questions.length > 0 ? (theme.questions[0].theme || theme.questions[0].category || "その他") : "その他";
                          return (
                            <a href={`/themes/${encodeURIComponent(rawThemeName)}`} class="theme-pill relative overflow-hidden">
                              <span class="theme-name leading-tight text-sm mb-1" set:html={theme.name.replace('（', '<br>（')}></span>
                              <span class="theme-pill-progress ml-2 mb-1" id={`theme-progress-${i}-${j}`}>0/${theme.questions.length}</span>
                              <div class="theme-pill-bar-container absolute bottom-0 left-0 right-0 h-1 bg-black/5">
                                <div class="theme-pill-bar h-full transition-all" id={`theme-bar-${i}-${j}`} style="width: 0%"></div>
                              </div>
                              <div class="theme-q-ids hidden" data-ids={qIds}></div>
                            </a>
                          );
                        })}
                      </div>
                      <a href={`/chapters/${chapterNum}`} class="block text-center text-sm font-bold opacity-80 hover:opacity-100 py-2 border border-current rounded-lg border-opacity-20 transition-opacity">
                        ✅ この章の問題をすべて解く →
                      </a>
                    </div>
                  ) : (
                    <p class="text-xs text-slate-400 mt-2">現在準備中です</p>
                  )}
                </div>
              </div>
            )})}
          </div>
        </section>

        <!-- Comparison Link Section -->
        <section class="comparison-section px-4 mb-xl">
          <a href="#" class="comparison-card">
            <div class="comparison-content">
              <div class="comparison-text">
                <span class="comparison-label">薬剤師が本音で比較</span>
                <h2 class="comparison-title">独学と通信講座、どっちが合格しやすい？薬剤師が本音で比較</h2>
              </div>
              <div class="comparison-arrow">→</div>
            </div>
          </a>
        </section>

        <!-- Articles Section -->
        <section class="articles-section px-4 mt-16 mb-8">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-black text-slate-800 flex items-center gap-2">
              <span class="w-2 h-6 bg-primary rounded-full"></span>
              お役立ち記事
            </h2>
          </div>

          <!-- タブ -->
          <p class="text-xs font-bold text-slate-400 mb-2 pl-1">
            カテゴリで絞り込む ↓
          </p>
          <div class="article-tabs grid grid-cols-2 gap-2 mb-6">
            {Object.keys(categoryGroups).map((tab, i) => (
              <button
                class={`article-tab-btn rounded-full font-black border-2 transition-all ${i === 0 ? 'active' : ''}`}
                data-tab={tab}
              >
                {tab}
              </button>
            ))}
          </div>

          <!-- タブコンテンツ -->
          {Object.entries(categoryGroups).map(([tab, arts], i) => (
            <div class="article-tab-content" data-content={tab} style={i !== 0 ? 'display:none' : ''}>
              <div class="articles-list flex flex-col gap-4">
                {arts.length > 0 ? arts.map((article) => (
                  <a href={`/articles/${(article as any).slug}`} class="article-card group">
                    <div class="article-card-image">
                      <img src={(article as any).image} alt={(article as any).title} />
                    </div>
                    <div class="article-card-body">
                      <div class="article-card-meta">
                        <span class="article-category">{(article as any).category}</span>
                      </div>
                      <h3 class="article-card-title group-hover:text-primary-dark transition-colors">
                        {(article as any).title}
                      </h3>
                      <p class="article-card-desc">{(article as any).description}</p>
                    </div>
                  </a>
                )) : (
                  <p class="text-sm text-slate-400 text-center py-8">記事を準備中です</p>
                )}
              </div>
            </div>
          ))}
        </section>
      </main>
    </div>
  </div>
</Layout>

<style>
  .page-wrapper {
    max-width: 480px;
    margin: 0 auto;
  }

  .py-xl {
    padding-top: 1.5rem;
    padding-bottom: 3rem;
  }

  .mt-sm { margin-top: var(--spacing-sm); }
  .mt-md { margin-top: var(--spacing-md); }
  .mt-xl { margin-top: 4rem; }

  /* ── Hero Header ── */
  /* ── Hero Section (Redesigned) ── */
  .hero-section {
    width: 100%;
    border-radius: var(--border-radius-lg);
    box-shadow: var(--shadow-sm);
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
  }
  
  .hero-image-wrapper {
    width: 100%;
    aspect-ratio: 16 / 9; /* アスペクト比を維持 */
    overflow: hidden;
    border-radius: var(--border-radius-lg) var(--border-radius-lg) 0 0; /* 上部のみ角丸 */
    background-color: #f8fafc; /* 読み込み前のプレースホルダー色 */
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: contain; /* イラスト全体が見切れずに収まるようにする */
    object-position: center bottom;
    display: block;
  }

  .hero-text-area {
    /* インラインでTailwindクラスを活用しているため、最小限の調整のみ */
    position: relative;
    z-index: 10;
  }
  .main-title {
    line-height: 1.3;
  }

  .main-subtitle {
    line-height: 1.5;
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-top: 2rem;
  }

  /* ── CTA Button ── */
  .cta-section {
    padding: 2rem 0;
  }

  .btn-primary-lg {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-primary) 0%, #0284c7 100%);
    color: white;
    font-size: 1.35rem;
    font-weight: 800;
    padding: 1.25rem 2.5rem;
    border-radius: 9999px;
    text-decoration: none;
    box-shadow: 0 8px 24px rgba(14, 165, 233, 0.35);
