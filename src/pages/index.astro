</style>

<script>
  function updateChapterProgress() {
    const wrappers = document.querySelectorAll('.chap-tile-wrapper');
    wrappers.forEach((wrapper, i) => {
      const themePills = wrapper.querySelectorAll('.theme-pill');
      let chapTotalMastered = 0;
      let chapTotalQuestions = 0;

      themePills.forEach((pill, j) => {
        const idsEl = pill.querySelector('.theme-q-ids') as HTMLElement;
        if (!idsEl || !idsEl.dataset.ids) return;
        
        const qIds = idsEl.dataset.ids.split(',');
        let themeMastered = 0;
        
        qIds.forEach(id => {
          if (localStorage.getItem(`touhan_mastered_${id}`) === 'true') {
            themeMastered++;
          }
        });

        const pillProgressEl = pill.querySelector('.theme-pill-progress');
        if (pillProgressEl) {
          pillProgressEl.textContent = `${themeMastered}/${qIds.length}`;
        }
        
        const pillBarEl = pill.querySelector('.theme-pill-bar') as HTMLElement;
        if (pillBarEl) {
          const pillPercent = qIds.length > 0 ? Math.round((themeMastered / qIds.length) * 100) : 0;
          pillBarEl.style.width = `${pillPercent}%`;
        }
        
        if (themeMastered === qIds.length && qIds.length > 0) {
          pill.classList.add('is-mastered');
        } else {
          pill.classList.remove('is-mastered');
        }

        chapTotalMastered += themeMastered;
        chapTotalQuestions += qIds.length;
      });

      const chapProgressText = wrapper.querySelector('.chap-progress-badge') as HTMLElement;
      const bar = wrapper.querySelector('.chap-progress-bar') as HTMLElement;
      if (chapTotalQuestions > 0) {
        const percent = Math.round((chapTotalMastered / chapTotalQuestions) * 100);
        if (chapProgressText) {
          chapProgressText.textContent = `${percent}% マスター（${chapTotalMastered}/${chapTotalQuestions}）`;
        }
        if (bar) bar.style.width = `${percent}%`;
      } else {
        if (chapProgressText) chapProgressText.textContent = `0%`;
        if (bar) bar.style.width = `0%`;
      }
    });
  }

  function setupAccordions() {
    const toggles = document.querySelectorAll('.chap-tile');
    toggles.forEach(toggle => {
      // Clean up old event listeners by replacing the node, just in case
      const newToggle = toggle.cloneNode(true) as HTMLElement;
      toggle.parentNode?.replaceChild(newToggle, toggle);

      newToggle.addEventListener('click', (e) => {
        // Prevent opening if the click was actually inside a link or something else (though now it's a button)
        if ((e.target as HTMLElement).closest('a')) return;
        
        const wrapper = newToggle.closest('.chap-tile-wrapper');
        if (wrapper) {
          wrapper.classList.toggle('is-open');
        }
      });
    });
  }

  import { getStats, getLastQuestionId, getUnmasteredIds, getIncorrectIds } from '../utils/storage';

  function initInteractive() {
    updateChapterProgress();
    setupAccordions();

    // トップページに戻ってきた時点で「今日の10問」などのセッション状態はリセットする
    sessionStorage.removeItem('touhan_daily_session');
    sessionStorage.removeItem('touhan_daily_index');
    sessionStorage.removeItem('touhan_daily_correct');
    sessionStorage.removeItem('touhan_daily_mastered');

    // --- トップページのボタンと進捗用ロジック ---
    const globalCountEl = document.getElementById('global-mastered-count');
    if (globalCountEl) {
      globalCountEl.textContent = getStats().toString();
    }
    
    const quizDataEl = document.getElementById('quiz-data-ids');
    const allIds = quizDataEl && quizDataEl.dataset.ids ? JSON.parse(quizDataEl.dataset.ids) : [];
    
    // 今日の10問
    const btnDaily = document.getElementById('btn-start-daily');
    if (btnDaily) {
      btnDaily.addEventListener('click', () => {
        const unmastered = getUnmasteredIds(allIds);
        if (unmastered.length === 0) {
          alert('すべての問題をマスターしました！全問正解です！');
          return;
        }
        // シャッフルして最大10問を抽出
        const shuffled = unmastered.sort(() => 0.5 - Math.random());
        const selected = shuffled.slice(0, 10);
        
        // セッションに10問の配列と現在のインデックスを持たせる
        sessionStorage.setItem('touhan_daily_session', JSON.stringify(selected));
        sessionStorage.setItem('touhan_daily_index', '0');
        sessionStorage.setItem('touhan_daily_correct', '0'); // 成績カウント用
        sessionStorage.setItem('touhan_daily_mastered', '0'); // 今回マスターした数カウント用
        
        // 1問目に飛ぶ
        window.location.href = `/questions/${selected[0]}`;
      });
    }

    // 模擬テスト（/mock-examへの遷移はリンクタグで対応済み）

    // 好きな所から始める（スムーズスクロール）
    const btnScroll = document.getElementById('btn-scroll-modules');
    if (btnScroll) {
      btnScroll.addEventListener('click', () => {
        const target = document.getElementById('modules-section');
        if (target) {
          // ヘッダーなどの高さを考慮してやや上にスクロールをオフセットするならここで調整可能
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    }

    // タブ切り替え
    const tabBtns = document.querySelectorAll('.article-tab-btn');
    const tabContents = document.querySelectorAll('.article-tab-content');
    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const target = (btn as HTMLElement).dataset.tab;
        tabBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        tabContents.forEach(content => {
          (content as HTMLElement).style.display =
            (content as HTMLElement).dataset.content === target ? '' : 'none';
        });
      });
    });
  }

  // Handle initial page load
  document.addEventListener('DOMContentLoaded', initInteractive);
</script>
