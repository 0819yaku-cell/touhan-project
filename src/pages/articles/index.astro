---
import Layout from '../../layouts/Layout.astro';
import articlesJson from '../../data/articles.json';
import { getCollection } from 'astro:content';

// コレクション記事を正規化するヘルパー
const normalizeEntries = (entries: any[], prefix: string) =>
  entries.map(entry => {
    const urlSlug = entry.data.slug ?? entry.id;
    return {
      href: `/articles/${prefix}/${urlSlug}`,
      title: entry.data.title,
      description: entry.data.description,
      date: entry.data.pubDate ?? '',
      image: entry.data.image ?? `/記事画像/${urlSlug}.webp`,
      category: entry.data.category ?? '',
    };
  });

const [kampoEntries, otcEntries, studyEntries] = await Promise.all([
  getCollection('kampo'),
  getCollection('otc'),
  getCollection('study'),
]);

// articles.jsonを正規化
const jsonNormalized = articlesJson.map(a => ({
  href: `/articles/${a.slug}`,
  title: a.title,
  description: a.description,
  date: a.date,
  image: a.image,
  category: a.category,
}));

// 漢方記事のみ抽出・日付降順
const kampoArticles = [
  ...normalizeEntries(kampoEntries, 'kampo'),
  ...normalizeEntries(otcEntries, 'otc'),
  ...normalizeEntries(studyEntries, 'study'),
  ...jsonNormalized,
].filter(a => a.category.includes('漢方'))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Layout title="漢方記事一覧 | 登録販売者のくすり教室">
  <div class="container page-wrapper py-xl animate-fade-in">
    <main class="main-content">
      <header class="mb-12 px-4">
        <a href="/" class="text-sm font-bold text-primary hover:underline mb-4 inline-block">← トップページに戻る</a>
        <h1 class="text-2xl font-black text-slate-800 flex items-center gap-2">
          <span class="w-2 h-8 bg-primary rounded-full"></span>
          漢方記事一覧
        </h1>
        <p class="text-slate-500 font-bold mt-2">試験に出る漢方を薬剤師が徹底解説します</p>
      </header>

      <section class="px-4">
        <div class="articles-list">
          {kampoArticles.map((article) => (
            <a href={article.href} class="article-card group">
              <div class="article-card-image">
                <img src={article.image} alt={article.title} />
              </div>
              <div class="article-card-body">
                <div class="article-card-meta">
                  <span class="article-category">{article.category}</span>
                  <span class="text-[0.65rem] text-slate-400 font-bold ml-2">{article.date}</span>
                </div>
                <h3 class="article-card-title group-hover:text-primary-dark transition-colors">
                  {article.title}
                </h3>
                <p class="article-card-desc">{article.description}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    </main>
  </div>
</Layout>

<style>
  .page-wrapper {
    max-width: 480px;
    margin: 0 auto;
  }

  .py-xl {
    padding-top: 2rem;
    padding-bottom: 4rem;
  }

  .articles-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }

  .article-card {
    display: flex;
    flex-direction: column;
    background: white;
    border-radius: 16px;
    text-decoration: none;
    border: 1px solid #f1f5f9;
    box-shadow: 0 2px 8px rgba(0,0,0,0.03);
    transition: all 0.3s ease;
    overflow: hidden;
  }

  .article-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.06);
    border-color: #e2e8f0;
  }

  .article-card-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    flex-shrink: 0;
  }

  .article-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .article-card-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    padding: 0.5rem;
  }

  .article-category {
    font-size: 0.6rem;
    font-weight: 800;
    color: var(--color-primary-dark);
    background: #f0f9ff;
    padding: 2px 6px;
    border-radius: 9999px;
    display: inline-block;
    margin-bottom: 0.3rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  .article-card-title {
    font-size: 0.75rem;
    font-weight: 900;
    color: #1e293b;
    line-height: 1.4;
    margin-bottom: 0.2rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .article-card-desc {
    font-size: 0.65rem;
    color: #64748b;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }

  @media (max-width: 400px) {
    .article-card-title {
      font-size: 0.7rem;
    }
    .article-card-desc {
      font-size: 0.6rem;
    }
  }
</style>
