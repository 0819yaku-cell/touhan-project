---
import Layout from '../../layouts/Layout.astro';
import articlesJson from '../../data/articles.json';
import { getCollection } from 'astro:content';

const normalizeEntries = (entries: any[], prefix: string) =>
  entries.map(entry => {
    const urlSlug = entry.data.slug ?? entry.id;
    return {
      href: `/articles/${prefix}/${urlSlug}`,
      slug: urlSlug,
      title: entry.data.title,
      description: entry.data.description ?? '',
      date: entry.data.pubDate ?? '',
      image: entry.data.image ?? `/記事画像/${urlSlug}.webp`,
      category: entry.data.category ?? '',
    };
  });

const [kampoEntries, otcEntries, studyEntries] = await Promise.all([
  getCollection('kampo'),
  getCollection('otc'),
  getCollection('study'),
]);

const jsonNormalized = (articlesJson as any[]).map(a => ({
  href: `/articles/${a.slug}`,
  slug: a.slug,
  title: a.title,
  description: a.description ?? '',
  date: a.date,
  image: a.image,
  category: a.category,
}));

const kampoArticles = [
  ...normalizeEntries(kampoEntries, 'kampo'),
  ...normalizeEntries(otcEntries, 'otc'),
  ...normalizeEntries(studyEntries, 'study'),
  ...jsonNormalized,
].filter(a => a.category.includes('漢方'))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const totalCount = kampoArticles.length;
---

<Layout title="漢方記事一覧 | 登録販売者のくすり教室">
  <div class="container page-wrapper py-xl animate-fade-in">
    <main class="main-content">
      <header class="mb-8 px-4">
        <a href="/" class="text-sm font-bold text-primary hover:underline mb-4 inline-block">← トップページに戻る</a>
        <h1 class="text-2xl font-black text-slate-800 flex items-center gap-2">
          <span class="w-2 h-8 bg-primary rounded-full"></span>
          漢方記事一覧
        </h1>
        <p class="text-slate-500 font-bold mt-2">試験に出る漢方を薬剤師が徹底解説します</p>
      </header>

      <section class="px-4">
        <div id="read-progress" class="read-progress-bar mb-4" style="display:none">
          <div class="progress-header">
            <span id="progress-text" class="text-sm font-bold text-emerald-700"></span>
            <button id="btn-reset" class="reset-btn">リセット</button>
          </div>
          <div class="progress-track">
            <div id="progress-fill" class="progress-fill"></div>
          </div>
        </div>

        <div class="articles-list" id="kampo-list">
          {kampoArticles.map((article) => (
            <a href={article.href} class="article-card group" data-slug={article.slug}>
              <div class="article-card-image">
                <img src={article.image} alt={article.title} loading="lazy" />
                <span class="read-badge">✓ 読了</span>
              </div>
              <div class="article-card-body">
                <div class="article-card-meta">
                  <span class="article-category">{article.category}</span>
                </div>
                <h3 class="article-card-title group-hover:text-primary-dark transition-colors">
                  {article.title}
                </h3>
                <p class="article-card-desc">{article.description}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    </main>
  </div>
</Layout>

<script define:vars={{ totalCount }}>
  document.addEventListener('DOMContentLoaded', () => {
    try {
      const visited = new Set(JSON.parse(localStorage.getItem('touhan_visited_articles') || '[]'));
      let readCount = 0;
      document.querySelectorAll('#kampo-list .article-card[data-slug]').forEach(card => {
        const slug = card.getAttribute('data-slug');
        if (slug && visited.has(slug)) {
          readCount++;
          const badge = card.querySelector('.read-badge');
          if (badge) badge.classList.add('read-badge--show');
          card.classList.add('card--read');
        }
      });
      if (readCount > 0) {
        const bar = document.getElementById('read-progress');
        const text = document.getElementById('progress-text');
        const fill = document.getElementById('progress-fill');
        if (bar) bar.style.display = 'block';
        if (text) text.textContent = `${totalCount}本中 ${readCount}本読了`;
        if (fill) fill.style.width = `${Math.round(readCount / totalCount * 100)}%`;
      }

      document.getElementById('btn-reset')?.addEventListener('click', () => {
        try {
          const slugsOnPage = [...document.querySelectorAll('#kampo-list .article-card[data-slug]')]
            .map(c => c.getAttribute('data-slug')).filter(Boolean);
          const visited = new Set(JSON.parse(localStorage.getItem('touhan_visited_articles') || '[]'));
          slugsOnPage.forEach(s => visited.delete(s));
          localStorage.setItem('touhan_visited_articles', JSON.stringify([...visited]));
          document.querySelectorAll('#kampo-list .article-card').forEach(c => {
            c.classList.remove('card--read');
            const badge = c.querySelector('.read-badge');
            if (badge) badge.classList.remove('read-badge--show');
          });
          const bar = document.getElementById('read-progress');
          if (bar) bar.style.display = 'none';
        } catch(e) {}
      });
    } catch(e) {}
  });
</script>

<style>
  .page-wrapper {
    max-width: 480px;
    margin: 0 auto;
  }

  .py-xl {
    padding-top: 2rem;
    padding-bottom: 4rem;
  }

  /* ── 進捗バー ── */
  .read-progress-bar {
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 12px;
    padding: 0.75rem 1rem;
  }

  .progress-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .reset-btn {
    font-size: 0.65rem;
    font-weight: 700;
    color: #6b7280;
    background: white;
    border: 1px solid #d1d5db;
    border-radius: 9999px;
    padding: 2px 10px;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .reset-btn:hover {
    background: #fee2e2;
    border-color: #fca5a5;
    color: #dc2626;
  }

  .progress-track {
    margin-top: 0.4rem;
    background: #dcfce7;
    border-radius: 9999px;
    height: 6px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: #10b981;
    border-radius: 9999px;
    transition: width 0.4s ease;
    width: 0%;
  }

  /* ── Articles Grid ── */
  .articles-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }

  .article-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: white;
    border-radius: 16px;
    text-decoration: none;
    border: 1px solid #f1f5f9;
    box-shadow: 0 2px 8px rgba(0,0,0,0.03);
    transition: all 0.3s ease;
    overflow: hidden;
  }

  .article-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.06);
    border-color: #e2e8f0;
  }

  .card--read {
    border-color: #bbf7d0;
  }

  .article-card-image {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    flex-shrink: 0;
  }

  .article-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── 読了バッジ ── */
  .read-badge {
    display: none;
    position: absolute;
    top: 5px;
    right: 5px;
    background: #10b981;
    color: white;
    font-size: 0.6rem;
    font-weight: 800;
    padding: 2px 6px;
    border-radius: 9999px;
    white-space: nowrap;
    box-shadow: 0 1px 4px rgba(0,0,0,0.15);
  }

  .read-badge--show {
    display: block;
  }

  .article-card-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    padding: 0.5rem;
  }

  .article-category {
    font-size: 0.6rem;
    font-weight: 800;
    color: var(--color-primary-dark);
    background: #f0f9ff;
    padding: 2px 6px;
    border-radius: 9999px;
    display: inline-block;
    margin-bottom: 0.3rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  .article-card-title {
    font-size: 0.75rem;
    font-weight: 900;
    color: #1e293b;
    line-height: 1.4;
    margin-bottom: 0.2rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .article-card-desc {
    font-size: 0.65rem;
    color: #64748b;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }

  @media (max-width: 400px) {
    .article-card-title { font-size: 0.7rem; }
    .article-card-desc  { font-size: 0.6rem; }
  }
</style>
