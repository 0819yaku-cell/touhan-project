---
import Layout from '../../layouts/Layout.astro';
import rawData from '../../data/questions.json';

// diagramHtml を除いた必要最小限のデータのみ渡す
const questionsData = rawData.map(q => ({
  id: String(q.id),
  chapter: q.chapter,
  question: q.question,
  correctAnswer: q.isCorrect as boolean,
  explanation: q.explanation,
}));
---

<Layout title="復習モード | 模擬テスト | 登録販売者のくすり教室" noindex={true}>
  <div class="container py-xl animate-fade-in">
    <div class="review-container">
      <header class="text-center mb-8">
        <div class="inline-block bg-amber-100 text-amber-700 px-4 py-1 rounded-full text-sm font-bold mb-4">
          復習モード
        </div>
        <h1 class="text-2xl font-black text-slate-800 mb-2 leading-tight">間違えた問題の復習</h1>
        <div class="h-1.5 w-20 bg-amber-400 mx-auto rounded-full"></div>
      </header>

      <!-- 問題なし表示 -->
      <div id="no-data" class="hidden bg-white rounded-3xl shadow p-8 text-center mb-8 border border-slate-100">
        <div class="text-4xl mb-4">✅</div>
        <p class="text-slate-700 font-black text-lg">保存された復習データがありません</p>
        <p class="text-slate-400 font-bold text-sm mt-2">模擬テストを受けると間違えた問題が保存されます</p>
      </div>

      <!-- 進捗バー -->
      <div id="progress-area" class="hidden mb-6">
        <div class="flex justify-between items-center mb-2">
          <span class="text-sm font-black text-slate-600">確認済み</span>
          <span id="progress-text" class="text-sm font-black text-amber-600">0 / 0問</span>
        </div>
        <div class="h-2 bg-slate-100 rounded-full overflow-hidden">
          <div id="progress-bar" class="h-full bg-amber-400 rounded-full transition-all duration-300" style="width:0%"></div>
        </div>
      </div>

      <!-- アコーディオン一覧 -->
      <div id="review-list" class="space-y-3 mb-10"></div>

      <!-- アクションボタン -->
      <div id="action-buttons" class="hidden grid gap-4">
        <a href="/mock-exam" class="block w-full bg-indigo-600 hover:bg-indigo-700 text-white font-black text-lg py-5 rounded-2xl text-center no-underline transition-all active:scale-95">
          模擬テストに挑戦する
        </a>
        <a href="/" class="block w-full bg-slate-100 hover:bg-slate-200 text-slate-700 font-black text-lg py-4 rounded-2xl text-center no-underline transition-all active:scale-95">
          トップへ
        </a>
      </div>
    </div>
  </div>
</Layout>

<script define:vars={{ questionsData }}>
  document.addEventListener('DOMContentLoaded', () => {
    try {
      const stored = localStorage.getItem('mockExamWrongAnswers');
      const wrongIds = stored ? JSON.parse(stored) : [];

      const noDataEl = document.getElementById('no-data');
      const progressArea = document.getElementById('progress-area');
      const reviewList = document.getElementById('review-list');
      const actionButtons = document.getElementById('action-buttons');
      const progressText = document.getElementById('progress-text');
      const progressBar = document.getElementById('progress-bar');

      if (!Array.isArray(wrongIds) || wrongIds.length === 0) {
        if (noDataEl) noDataEl.classList.remove('hidden');
        if (actionButtons) actionButtons.classList.remove('hidden');
        return;
      }

      const wrongQuestions = wrongIds
        .map(id => questionsData.find(q => q.id === String(id)))
        .filter(Boolean);

      if (wrongQuestions.length === 0) {
        if (noDataEl) noDataEl.classList.remove('hidden');
        if (actionButtons) actionButtons.classList.remove('hidden');
        return;
      }

      if (progressArea) progressArea.classList.remove('hidden');
      if (actionButtons) actionButtons.classList.remove('hidden');

      let confirmedCount = 0;
      const total = wrongQuestions.length;

      function updateProgress() {
        if (progressText) progressText.textContent = `${confirmedCount} / ${total}問`;
        if (progressBar) progressBar.style.width = `${Math.round(confirmedCount / total * 100)}%`;
      }
      updateProgress();

      wrongQuestions.forEach((q, i) => {
        const correctLabel = q.correctAnswer ? '○' : '×';
        const wrongLabel = q.correctAnswer ? '×' : '○';
        const chapterLabel = typeof q.chapter === 'number' ? `第${q.chapter}章` : q.chapter;

        const item = document.createElement('div');
        item.className = 'review-item bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden';
        item.innerHTML = `
          <button class="accordion-trigger w-full text-left p-4 flex items-start gap-3 cursor-pointer bg-transparent border-none" aria-expanded="false">
            <span class="review-num flex-shrink-0 w-7 h-7 rounded-full bg-amber-100 text-amber-700 text-xs font-black flex items-center justify-center mt-0.5">${i + 1}</span>
            <div class="flex-1 min-w-0">
              <span class="text-[0.65rem] font-black text-slate-400 block mb-1">${chapterLabel}</span>
              <p class="question-text text-sm font-bold text-slate-800 leading-relaxed m-0">${q.question}</p>
            </div>
            <span class="accordion-arrow flex-shrink-0 text-slate-400 text-xs mt-1 transition-transform duration-200">▼</span>
          </button>
          <div class="accordion-body hidden px-4 pb-4 border-t border-slate-50">
            <div class="mt-3 mb-3 flex gap-3">
              <div class="answer-box flex-1 rounded-xl p-3 bg-red-50 border border-red-100 text-center">
                <div class="text-[0.6rem] font-black text-red-400 mb-1">あなたの答え</div>
                <div class="text-2xl font-black text-red-500">${wrongLabel}</div>
              </div>
              <div class="answer-box flex-1 rounded-xl p-3 bg-emerald-50 border border-emerald-100 text-center">
                <div class="text-[0.6rem] font-black text-emerald-500 mb-1">正解</div>
                <div class="text-2xl font-black text-emerald-600">${correctLabel}</div>
              </div>
            </div>
            <div class="bg-slate-50 rounded-xl p-3 border border-slate-100">
              <p class="text-xs font-black text-slate-500 mb-1">解説</p>
              <p class="text-sm text-slate-700 font-bold leading-relaxed m-0">${q.explanation}</p>
            </div>
          </div>
        `;

        const trigger = item.querySelector('.accordion-trigger');
        const body = item.querySelector('.accordion-body');
        const arrow = item.querySelector('.accordion-arrow');
        let opened = false;

        trigger.addEventListener('click', () => {
          const isOpen = !body.classList.contains('hidden');
          if (isOpen) {
            body.classList.add('hidden');
            trigger.setAttribute('aria-expanded', 'false');
            arrow.style.transform = '';
          } else {
            body.classList.remove('hidden');
            trigger.setAttribute('aria-expanded', 'true');
            arrow.style.transform = 'rotate(180deg)';
            if (!opened) {
              opened = true;
              confirmedCount++;
              updateProgress();
              // 確認済みスタイル
              item.style.borderColor = '#bbf7d0';
            }
          }
        });

        reviewList.appendChild(item);
      });

    } catch(e) {
      console.error(e);
    }
  });
</script>

<style>
  .py-xl { padding-top: 1.5rem; padding-bottom: 4rem; }

  .review-container {
    max-width: 480px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .animate-fade-in {
    animation: fadeIn 0.5s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .accordion-trigger:hover {
    background: #fafafa !important;
  }

  #action-buttons {
    display: grid;
  }
</style>
